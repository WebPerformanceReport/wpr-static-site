<form
  id="subscribeForm"
  class="wpr-subscribe"
  action="https://webperformancereport.com/report/proxy/subscribe.php"
  method="post"
  novalidate
  data-enhanced="true"
>
  <!-- Hidden: source dinámico -->
  <input type="hidden" name="source" value="Observatory" />

  <!-- Hidden timestamp -->
  <input type="hidden" name="ts" value="" />

  <!-- Honeypot -->
  <div class="hp" aria-hidden="true" hidden>
    <label for="company">Company</label>
    <input id="company" name="company" type="text" tabindex="-1" autocomplete="off" />
  </div>

  <!-- Email -->
  <div class="field">
    <label for="email">Enter your email address <span>*</span></label>
    <input
      id="email"
      name="email"
      type="email"
      required
      inputmode="email"
      autocomplete="email"
      placeholder="EMAIL"
      aria-describedby="email-hint"
    />
    <p id="email-hint" class="hint">
      Provide your email address to subscribe. Example: abc@xyz.com
    </p>
  </div>

<!-- Website Domain -->
<div class="field">
  <label for="domain">Enter your Domain <span>*</span></label>
  <input
    id="domain"
    name="domain"
    type="text"
    required
    inputmode="url"
    placeholder="Scan a website (e.g. example.com)"
    pattern="^(?:[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?\.)+[a-z]{2,}$"
    aria-describedby="domain-hint"
  />
  <p id="domain-hint" class="hint">
    Provide your Domain. Example: <code>example.com</code>
  </p>
</div>

  <!-- Consent -->
  <div class="field checkbox">
    <input id="consent" name="consent" type="checkbox" value="on" required />
    <label for="consent">
      I agree to receive your reports and accept the <a href="/cookie-policy/">Cookie Policy</a>.
    </label>
  </div>

  <!-- Submit -->
  <div class="actions">
    <button type="submit" data-submit>SUBSCRIBE</button>
  </div>

  <!-- Footnote -->
  <p class="footnote">
    Built using Mozilla’s HTTP Observatory.
  </p>
</form>

<div id="wpr-messages" class="wpr-messages" role="status" aria-live="polite" hidden></div>

{% include "layouts/shared/form-subscribe-script.njk" %}
